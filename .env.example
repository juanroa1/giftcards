# Login
LOGIN_URL=https://infoproduccion.rbm.com.co/webclient/Login.xhtml
RBM_USERNAME=
RBM_PASSWORD=

# Selectores CSS o XPath (Playwright)
USERNAME_SELECTOR=#username
PASSWORD_SELECTOR=#value
SUBMIT_SELECTOR=#j_id_1y
SALIDAS_PARENT_SELECTOR=
SALIDAS_SELECTOR=#j_id_1d\\:0_0_7\\:j_id_1y
DOWNLOAD_SELECTOR=a.ItemName
FILE_PREFIX=MV

# Tiempos
TIMEOUT_MS=45000
POST_LOGIN_WAIT_MS=2500

# Supabase (service role para poder escribir en Storage)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=rbm-files
SUPABASE_OBJECT_PATH=salidas

# Opcional en local si no detecta Chromium automáticamente
# CHROMIUM_EXECUTABLE_PATH=/ruta/a/chromium
